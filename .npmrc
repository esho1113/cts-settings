# Lockfile resolves tarballs from Procore Artifactory; installs need auth.
# Vercel: add NPM_TOKEN (Artifactory identity / npm token) under Environment Variables.
# Local: export NPM_TOKEN="..." in your shell, or merge with your existing ~/.npmrc workflow.
registry=https://artifacts.procoretech.com/artifactory/api/npm/npm/
//artifacts.procoretech.com/artifactory/api/npm/npm/:_authToken=${NPM_TOKEN}
always-auth=true
